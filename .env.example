# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GOOGLE_SHEET_URL: Optional. Link to the Google Sheet (shared with "Anyone with the link can view").
# Example: https://docs.google.com/spreadsheets/d/1abcdefg12345/edit
GOOGLE_SHEET_URL=""

# GOOGLE_APPS_SCRIPT_URL: Optional. Web app URL to submit enquiries.
# Example: https://script.google.com/macros/s/AKfycbz_abc123/exec
GOOGLE_APPS_SCRIPT_URL=""

# ADMIN_PASSWORD: Password to view local enquiries in the dashboard. Defaults to "shamim123".
ADMIN_PASSWORD="shamim123"
